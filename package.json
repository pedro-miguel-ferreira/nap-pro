{
  "name": "nap-pro",
  "version": "0.1.0",
  "description": "NAP Pro — multi-agent orchestrator with hierarchical tree, pause/resume, live diffs, and per-agent worktrees",
  "main": "out/main/main.js",
  "bin": {
    "nap-pro": "out/cli/cli/nap.js"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "npm run build && electron .",
    "typecheck": "tsc --noEmit",
    "build:cli": "tsc -p tsconfig.cli.json",
    "test:small": "vitest run",
    "test:medium": "npm run build && npm run build:cli && NAP_TEST=1 npx playwright test",
    "test:medium:headed": "npm run build && npm run build:cli && NAP_TEST=1 HEADED=1 npx playwright test",
    "test": "npm run test:small && npm run test:medium",
    "postinstall": "cd node_modules/node-pty && node-gyp rebuild --runtime=electron --target=$(node -e \"console.log(require('../electron/package.json').version)\") --arch=$(node -e \"console.log(process.arch)\") --dist-url=https://electronjs.org/headers"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^33.0.0",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0"
  }
}
